---
layout: layouts/base.njk
title: Stores | Bollag Guggenheim
---
{% include "components/site-header.njk" %}

<section class="relative isolate overflow-hidden bg-ink text-bone">
  <div class="absolute inset-0 overflow-hidden">
    <video
      class="hero-image h-full w-full object-cover object-center"
      autoplay
      muted
      loop
      playsinline
      poster="{{ stores.hero.image }}"
      aria-hidden="true"
    >
      <source src="/assets/media/stores/stores-hero.mp4" type="video/mp4">
      <img src="{{ stores.hero.image }}" alt="Bollag Guggenheim retail environment" class="hero-image h-full w-full object-cover object-center">
    </video>
    <div class="page-hero-overlay absolute inset-0"></div>
  </div>
  <div class="relative mx-auto flex min-h-[78svh] w-full max-w-[1600px] items-end px-6 pb-12 pt-32 sm:px-10 lg:px-16 lg:pb-16">
    <div class="relative max-w-[62rem]">
      <div class="absolute -left-16 bottom-[-3rem] h-[24rem] w-[34rem] rounded-full bg-[radial-gradient(circle,rgba(6,8,10,0.5),rgba(6,8,10,0.3)_42%,rgba(6,8,10,0.12)_68%,transparent_100%)] blur-3xl sm:h-[28rem] sm:w-[40rem]"></div>
      <div class="relative">
      <p class="type-eyebrow-hero mb-4 text-bone/64 [text-shadow:0_3px_12px_rgba(0,0,0,0.4)]" data-reveal>{{ stores.hero.eyebrow }}</p>
      <h1 class="type-hero-title max-w-[12ch] [text-shadow:0_12px_32px_rgba(0,0,0,0.58)]" data-reveal>
        {{ stores.hero.title }}
      </h1>
      <p class="type-body-lg mt-6 max-w-[42rem] text-bone/88 [text-shadow:0_8px_20px_rgba(0,0,0,0.46)]" data-reveal>
        {{ stores.hero.summary }}
      </p>
      <div class="type-meta mt-8 flex flex-wrap gap-x-8 gap-y-3 text-bone/60 [text-shadow:0_5px_16px_rgba(0,0,0,0.42)]" data-reveal>
        <span>2 Monobrand Stores</span>
        <span>2 Multibrand Stores</span>
        <span>1 Outlet</span>
        <span>1 Online Shop</span>
      </div>
      </div>
    </div>
  </div>
</section>

<section class="bg-[#FAF8F6] text-ink">
  <div class="mx-auto w-full max-w-[1600px] px-6 py-16 sm:px-10 lg:px-16 lg:py-24">
    <div class="mb-12 flex flex-col gap-6 border-t border-black/10 pt-8 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-[38rem]">
        <p class="type-eyebrow mb-4 text-black/40" data-reveal>Store Network</p>
        <h2 class="type-section-title max-w-[11ch] text-black" data-reveal>
          Physical retail with a sharper point of view.
        </h2>
      </div>
      <p class="type-body-sm max-w-[24rem] text-black/58" data-reveal>
        From Zurich to Spreitenbach and Schonenwerd, the network connects brand presentation, customer insight, and direct retail experience.
      </p>
    </div>

    <div class="space-y-16 lg:space-y-24">
      {% for group in stores.groups %}
        <section class="grid gap-10 lg:grid-cols-[minmax(0,0.34fr)_minmax(0,0.66fr)] lg:gap-12">
          <div class="lg:sticky lg:top-28 lg:self-start">
            <p class="type-eyebrow mb-4 text-black/40" data-reveal>{{ group.label }}</p>
            <h3 class="type-section-title-block text-black" data-reveal>{{ group.title }}</h3>
            <p class="type-body mt-5 max-w-[22rem] text-black/68" data-reveal>{{ group.intro }}</p>
          </div>

          <div class="grid gap-5 {% if group.stores | length > 1 %}xl:grid-cols-2{% endif %}">
            {% for store in group.stores %}
              <article class="group overflow-hidden border border-black/10 bg-white/38 transition duration-300 hover:border-black/18 hover:bg-white/46" data-reveal>
                <div class="relative aspect-[4/3] overflow-hidden bg-black/5">
                  <img src="{{ store.image }}" alt="{{ store.name }}" class="h-full w-full object-cover transition duration-[900ms] group-hover:scale-[1.035] group-hover:opacity-92">
                  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.06),rgba(0,0,0,0.42)_100%)]"></div>
                  <div class="absolute inset-x-0 bottom-0 p-5 lg:p-6">
                    <p class="type-label text-white/60">{{ group.title }}</p>
                    <h4 class="type-subcard-title mt-2 text-white">{{ store.name }}</h4>
                  </div>
                </div>
                <div class="grid gap-8 p-5 lg:p-6">
                  <div>
                    <p class="type-label mb-3 text-black/38">Address</p>
                    <div class="type-body text-black/74">
                      {% for line in store.address %}
                        <p>{{ line }}</p>
                      {% endfor %}
                    </div>
                  </div>
                  <div class="grid gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
                    <div>
                      <p class="type-label mb-3 text-black/38">Contact</p>
                      <a href="{{ store.phoneHref }}" class="cta-button cta-button--dark">{{ store.phoneLabel }}</a>
                    </div>
                    <div>
                      <p class="type-label mb-3 text-black/38">Opening Hours</p>
                      <div class="type-body-sm text-black/66">
                        {% for line in store.hours %}
                          <p>{{ line }}</p>
                        {% endfor %}
                      </div>
                    </div>
                  </div>
                </div>
              </article>
            {% endfor %}
          </div>
        </section>
      {% endfor %}
    </div>
  </div>
</section>

{% include "components/site-footer.njk" %}
