<section class="relative isolate min-h-[56svh] overflow-hidden bg-bone sm:min-h-[80svh]">
  <div class="absolute inset-0">
    <video
      class="hero-image absolute inset-0 h-full w-full object-cover object-[{{ cms.home.hero.mobileObjectPosition }}] sm:object-[{{ cms.home.hero.smallObjectPosition }}] md:object-[{{ cms.home.hero.desktopObjectPosition }}]"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="{{ cms.home.hero.poster }}"
      aria-hidden="true"
    >
      <source src="{{ cms.home.hero.video }}" type="video/mp4">
      <img src="{{ cms.home.hero.poster }}" alt="{{ cms.home.hero.videoAlt }}" class="hero-image absolute inset-0 h-full w-full object-cover object-[{{ cms.home.hero.mobileObjectPosition }}] sm:object-[{{ cms.home.hero.smallObjectPosition }}] md:object-[{{ cms.home.hero.desktopObjectPosition }}]">
    </video>
    <div class="absolute inset-x-0 top-0 h-24 bg-[linear-gradient(180deg,rgba(0,0,0,0.34),rgba(0,0,0,0))] sm:h-28 lg:h-32"></div>
    <div class="absolute inset-x-0 bottom-0 h-32 bg-[linear-gradient(180deg,rgba(0,0,0,0),rgba(0,0,0,0.22))] sm:h-40 lg:h-48"></div>
  </div>

  <div class="relative mx-auto flex min-h-[56svh] w-full max-w-[1600px] items-end px-5 pb-6 sm:min-h-[80svh] sm:px-8 sm:pb-8 lg:px-12 lg:pb-10">
    <div class="hero-typewriter-block" data-hero-typewriter-block data-reveal>
      <div class="hero-typewriter" data-hero-typewriter data-typewriter-text="{{ cms.home.hero.title }}">
        {{ cms.home.hero.title }}
      </div>
      <div class="hero-typewriter-subline" data-hero-typewriter-subline>
        {{ cms.home.hero.subline }}
      </div>
    </div>
  </div>
</section>
