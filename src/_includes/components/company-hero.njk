<section class="relative isolate min-h-[76svh] overflow-hidden bg-ink text-bone">
  <div class="absolute inset-0 overflow-hidden">
    <video
      class="hero-image h-full w-full object-cover object-center md:object-[center_30%]"
      autoplay
      muted
      loop
      playsinline
      poster="{{ cms.company.hero.poster }}"
      aria-hidden="true"
    >
      <source src="{{ cms.company.hero.video }}" type="video/mp4">
      <img src="{{ cms.company.hero.poster }}" alt="{{ cms.company.hero.videoAlt }}" class="hero-image h-full w-full object-cover object-center md:object-[center_30%]">
    </video>
    <div class="page-hero-overlay absolute inset-0"></div>
  </div>
  <div class="relative mx-auto flex min-h-[76svh] w-full max-w-[1600px] items-end px-6 pb-12 pt-28 sm:px-10 lg:px-16 lg:pb-16">
    <div class="max-w-[56rem]">
      <p class="type-eyebrow-hero mb-4 text-bone/54" data-reveal>{{ cms.company.hero.eyebrow }}</p>
      <h1 class="type-hero-title max-w-[11ch]" data-reveal>
        {{ cms.company.hero.title }}
      </h1>
      <p class="type-body-lg mt-6 max-w-[34rem] text-bone/72" data-reveal>
        {{ cms.company.hero.summary }}
      </p>
    </div>
  </div>
</section>
