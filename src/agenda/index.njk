---
layout: layouts/base.njk
title: Agenda | Bollag Guggenheim
---
{% include "components/site-header.njk" %}

<section class="relative isolate overflow-hidden bg-ink text-bone">
  <div class="absolute inset-0 overflow-hidden">
    <video
      class="hero-image h-full w-full object-cover object-center"
      autoplay
      muted
      loop
      playsinline
      poster="{{ agenda.hero.image }}"
      aria-hidden="true"
    >
      <source src="/assets/media/page-heroes/agenda-hero.mp4" type="video/mp4">
      <img src="{{ agenda.hero.image }}" alt="Bollag Guggenheim agenda view" class="hero-image h-full w-full object-cover object-center">
    </video>
    <div class="page-hero-overlay absolute inset-0"></div>
  </div>
  <div class="relative mx-auto flex min-h-[78svh] w-full max-w-[1600px] items-end px-6 pb-12 pt-32 sm:px-10 lg:px-16 lg:pb-16">
    <div class="max-w-[64rem]">
      <p class="type-eyebrow-hero mb-4 text-bone/54" data-reveal>{{ agenda.hero.eyebrow }}</p>
      {% if agenda.hero.quote %}
      <div class="mb-7 font-display text-[1.45rem] italic leading-none tracking-[-0.03em] text-bone/72 sm:text-[1.8rem]" data-reveal>
        {{ agenda.hero.quote }}
      </div>
      {% endif %}
      <h1 class="type-hero-title max-w-[12ch]" data-reveal>
        {{ agenda.hero.title }}
      </h1>
      <p class="type-body-lg mt-6 max-w-[42rem] text-bone/82" data-reveal>
        {{ agenda.hero.summary }}
      </p>
    </div>
  </div>
</section>

<section class="bg-[#FAF8F6] text-ink">
  <div class="mx-auto w-full max-w-[1600px] px-6 py-16 sm:px-10 lg:px-16 lg:py-24">
    <div class="mb-12 flex flex-col gap-6 border-t border-black/10 pt-8 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-[38rem]">
        <p class="type-eyebrow mb-4 text-black/40" data-reveal>{{ agenda.calendarSection.eyebrow }}</p>
        <h2 class="type-section-title max-w-[11ch] text-black" data-reveal>
          {{ agenda.calendarSection.title }}
        </h2>
      </div>
      <p class="type-body-sm max-w-[24rem] text-black/58" data-reveal>
        {{ agenda.calendarSection.summary }}
      </p>
    </div>

    <div class="space-y-14 lg:space-y-20">
      {% for month in agenda.months %}
        <section class="grid gap-8 lg:grid-cols-[minmax(0,0.28fr)_minmax(0,0.72fr)] lg:gap-10">
          <div class="lg:sticky lg:top-28 lg:self-start">
            <h3 class="type-section-title-block text-black lg:text-[3.6rem]" data-reveal>{{ month.month }}</h3>
          </div>
          <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            {% for event in month.events %}
              <article class="group flex min-h-[18rem] flex-col justify-between border border-black/10 bg-white/36 p-5 transition duration-300 hover:border-black/18 hover:bg-white/48 lg:p-6" data-reveal>
                <div>
                  <p class="type-label mb-4 text-black/40">{{ event.dateLabel }}</p>
                  <h4 class="type-subcard-title text-black">{{ event.brand }}</h4>
                  <p class="type-body mt-4 text-black/70">{{ event.detail }}</p>
                </div>
                <div class="mt-8 border-t border-black/10 pt-4">
                  <p class="type-label text-black/38">Location</p>
                  <p class="type-body-sm mt-2 text-black/64">{{ event.location }}</p>
                </div>
              </article>
            {% endfor %}
          </div>
        </section>
      {% endfor %}
    </div>
  </div>
</section>

<section class="bg-[#FAF7F4] text-ink">
  <div class="mx-auto w-full max-w-[1600px] px-6 py-16 sm:px-10 lg:px-16 lg:py-20">
    <div class="grid gap-8 border-t border-black/10 pt-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
      <div>
        <p class="type-eyebrow mb-4 text-black/42" data-reveal>{{ agenda.cta.eyebrow }}</p>
        <h2 class="type-section-title-sm max-w-[14ch] text-black" data-reveal>
          {{ agenda.cta.title }}
        </h2>
      </div>
      <a href="{{ agenda.cta.buttonHref }}" class="cta-button cta-button--dark" data-reveal>
        <span>{{ agenda.cta.buttonLabel }}</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

{% include "components/site-footer.njk" %}
