---
layout: layouts/base.njk
title: Agenda | Bollag Guggenheim
---
{% include "components/site-header.njk" %}

<section class="relative isolate overflow-hidden bg-ink text-bone">
  <div class="absolute inset-0 overflow-hidden">
    <img src="{{ agenda.hero.image }}" alt="Bollag Guggenheim agenda view" class="hero-image h-full w-full object-cover object-center">
    <div class="page-hero-overlay absolute inset-0"></div>
  </div>
  <div class="relative mx-auto flex min-h-[78svh] w-full max-w-[1600px] items-end px-6 pb-12 pt-32 sm:px-10 lg:px-16 lg:pb-16">
    <div class="max-w-[64rem]">
      <p class="mb-4 text-[0.72rem] uppercase tracking-[0.3em] text-bone/54" data-reveal>{{ agenda.hero.eyebrow }}</p>
      <div class="mb-7 font-display text-[1.45rem] italic leading-none tracking-[-0.03em] text-bone/72 sm:text-[1.8rem]" data-reveal>
        {{ agenda.hero.quote }}
      </div>
      <h1 class="max-w-[12ch] font-display text-[2.25rem] leading-[0.9] tracking-[-0.055em] sm:text-[3.45rem] lg:text-[4.5rem]" data-reveal>
        {{ agenda.hero.title }}
      </h1>
      <p class="mt-6 max-w-[42rem] font-['Inter',_'Helvetica_Neue',_Arial,_sans-serif] text-base leading-relaxed text-bone/82 sm:text-lg lg:text-[1.08rem]" data-reveal>
        {{ agenda.hero.summary }}
      </p>
    </div>
  </div>
</section>

<section class="bg-[#FAF8F6] text-ink">
  <div class="mx-auto w-full max-w-[1600px] px-6 py-16 sm:px-10 lg:px-16 lg:py-24">
    <div class="mb-12 flex flex-col gap-6 border-t border-black/10 pt-8 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-[38rem]">
        <p class="mb-4 text-[0.7rem] uppercase tracking-[0.32em] text-black/40" data-reveal>Showroom Calendar</p>
        <h2 class="max-w-[11ch] font-display text-[1.9rem] leading-[0.92] tracking-[-0.045em] text-black sm:text-[2.55rem] lg:text-[3.4rem]" data-reveal>
          Seasonal windows across the portfolio.
        </h2>
      </div>
      <p class="max-w-[24rem] font-['Inter',_'Helvetica_Neue',_Arial,_sans-serif] text-sm leading-relaxed text-black/58 lg:text-[0.98rem]" data-reveal>
        A direct view into upcoming collection presentations, delivery periods, and showroom timing in Zurich.
      </p>
    </div>

    <div class="space-y-14 lg:space-y-20">
      {% for month in agenda.months %}
        <section class="grid gap-8 lg:grid-cols-[minmax(0,0.28fr)_minmax(0,0.72fr)] lg:gap-10">
          <div class="lg:sticky lg:top-28 lg:self-start">
            <p class="text-[0.7rem] uppercase tracking-[0.32em] text-black/40" data-reveal>Calendar</p>
            <h3 class="mt-3 font-display text-[2.2rem] leading-[0.94] tracking-[-0.04em] text-black sm:text-[2.8rem] lg:text-[3.6rem]" data-reveal>{{ month.month }}</h3>
          </div>
          <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            {% for event in month.events %}
              <article class="group flex min-h-[18rem] flex-col justify-between border border-black/10 bg-white/36 p-5 transition duration-300 hover:border-black/18 hover:bg-white/48 lg:p-6" data-reveal>
                <div>
                  <p class="mb-4 text-[0.68rem] uppercase tracking-[0.28em] text-black/40">{{ event.dateLabel }}</p>
                  <h4 class="font-display text-[2rem] leading-[0.94] tracking-[-0.04em] text-black">{{ event.brand }}</h4>
                  <p class="mt-4 font-['Inter',_'Helvetica_Neue',_Arial,_sans-serif] text-[0.98rem] leading-[1.75] text-black/70">{{ event.detail }}</p>
                </div>
                <div class="mt-8 border-t border-black/10 pt-4">
                  <p class="text-[0.68rem] uppercase tracking-[0.28em] text-black/38">Location</p>
                  <p class="mt-2 font-['Inter',_'Helvetica_Neue',_Arial,_sans-serif] text-sm leading-relaxed text-black/64">{{ event.location }}</p>
                </div>
              </article>
            {% endfor %}
          </div>
        </section>
      {% endfor %}
    </div>
  </div>
</section>

<section class="bg-[#FAF7F4] text-ink">
  <div class="mx-auto w-full max-w-[1600px] px-6 py-16 sm:px-10 lg:px-16 lg:py-20">
    <div class="grid gap-8 border-t border-white/10 pt-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
      <div>
        <p class="mb-4 text-[0.7rem] uppercase tracking-[0.32em] text-black/42" data-reveal>Appointments</p>
        <h2 class="max-w-[14ch] font-display text-[1.7rem] leading-[0.94] tracking-[-0.04em] text-black sm:text-[2.25rem] lg:text-[2.8rem]" data-reveal>
          For showroom enquiries, contact the team directly.
        </h2>
      </div>
      <a href="/contact/" class="cta-button cta-button--dark" data-reveal>
        <span>Go to Contact</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

{% include "components/site-footer.njk" %}
